<?xml version="1.0"?>
<sdf version="1.9">
  <world name="single_real_tomato_test">
    <plugin name="gz::sim::systems::Physics" filename="gz-sim-physics-system"/>
    <plugin name="gz::sim::systems::UserCommands" filename="gz-sim-user-commands-system"/>
    <plugin name="gz::sim::systems::SceneBroadcaster" filename="gz-sim-scene-broadcaster-system"/>
    <plugin name="gz::sim::systems::Contact" filename="gz-sim-contact-system"/>

    <gui fullscreen="false">
      <plugin name="3D View" filename="GzScene3D">
        <gz-gui>
          <title>3D View</title>
          <property type="bool" key="showTitleBar">0</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.7 0.7 0.7</ambient_light>
        <background_color>0.88 0.90 0.92</background_color>
        <camera_pose>0.8 -1.4 0.8 0 0.45 2.6</camera_pose>
      </plugin>
      <plugin name="World control" filename="WorldControl"/>
      <plugin name="Entity tree" filename="EntityTree"/>
    </gui>

    <gravity>0 0 -9.8</gravity>
    <scene>
      <grid>true</grid>
      <ambient>0.55 0.55 0.55 1</ambient>
      <background>0.82 0.84 0.86 1</background>
      <shadows>false</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0.15 0.15 0.15 1</specular>
      <direction>-0.4 0.3 -1</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>6 6</size></plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>6 6</size></plane>
          </geometry>
          <material>
            <ambient>0.50 0.47 0.40 1</ambient>
            <diffuse>0.50 0.47 0.40 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Simple stem to hold the tomato -->
    <model name="tomato_plant">
      <pose>-0.45 0.0 0.0 0 0 0</pose>
      <static>true</static>
      <link name="stem">
        <pose>0 0 0.35 0 0 0</pose>
        <visual name="vis">
          <geometry>
            <cylinder><radius>0.008</radius><length>0.70</length></cylinder>
          </geometry>
          <material>
            <ambient>0.15 0.4 0.15 1</ambient>
            <diffuse>0.15 0.4 0.15 1</diffuse>
          </material>
        </visual>
      </link>
      <!-- Detachable joint: publish to /detach/tomato_ripe_test_0 to release -->
      <plugin filename="gz-sim-detachable-joint-system"
              name="gz::sim::systems::DetachableJoint">
        <parent_link>stem</parent_link>
        <child_model>tomato_ripe_test_0</child_model>
        <child_link>link</child_link>
        <detach_topic>/detach/tomato_ripe_test_0</detach_topic>
        <attach_topic>/attach/tomato_ripe_test_0</attach_topic>
        <output_topic>/detach_state/tomato_ripe_test_0</output_topic>
      </plugin>
    </model>

    <!--
      Tomato at world (-0.45, 0.0, 0.70).
      Robot at (-0.85, 0, 0.25) → fr3_link0 at (-0.85, 0, 0.4215).
      In fr3_link0 frame: (0.40, 0.0, 0.28) → distance = 0.49m.
      FR3 max reach 0.855m → uses only 57% of reach. Very comfortable.
    -->
    <model name="tomato_ripe_test_0">
      <pose>-0.45 0.0 0.70 0 0 0</pose>
      <static>false</static>
      <link name="link">
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <mesh>
              <uri>model://tomato_ripe/meshes/tomatoripe.glb</uri>
              <scale>1.50 1.50 1.50</scale>
            </mesh>
          </geometry>
        </visual>
        <collision name="collision">
          <geometry>
            <sphere><radius>0.0375</radius></sphere>
          </geometry>
        </collision>
      </link>
    </model>

  </world>
</sdf>
