<?xml version='1.0' encoding='utf-8'?>
<sdf version="1.9">
  <world name="single_plant_tomato_test">
    <plugin name="gz::sim::systems::Physics" filename="gz-sim-physics-system" />
    <plugin name="gz::sim::systems::UserCommands" filename="gz-sim-user-commands-system" />
    <plugin name="gz::sim::systems::SceneBroadcaster" filename="gz-sim-scene-broadcaster-system" />
    <plugin name="gz::sim::systems::Contact" filename="gz-sim-contact-system" />

    <gui fullscreen="false">
      <plugin name="3D View" filename="GzScene3D">
        <gz-gui>
          <title>3D View</title>
          <property type="bool" key="showTitleBar">0</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.6 0.6 0.6</ambient_light>
        <background_color>0.9 0.9 0.9</background_color>
        <camera_pose>2.4 -3.0 2.2 0 0.45 2.35</camera_pose>
      </plugin>
      <plugin name="World control" filename="WorldControl" />
      <plugin name="Entity tree" filename="EntityTree" />
    </gui>

    <gravity>0 0 -9.8</gravity>
    <scene>
      <grid>true</grid>
      <ambient>0.5 0.5 0.5 1</ambient>
      <background>0.8 0.8 0.8 1</background>
      <shadows>false</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.2 -1</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>8 8</size></plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>8 8</size></plane>
          </geometry>
          <material>
            <ambient>0.55 0.50 0.42 1</ambient>
            <diffuse>0.55 0.50 0.42 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

<model name="plant_B_0">
      <pose>0 0 -0.425 0 0 1.5708</pose>
      <static>true</static>
      <link name="fide_govdesi">
        <pose>0 0 0.796845 0 0 0</pose>
        <visual name="fide_vis">
          <geometry>
            <mesh>
              <uri>model://Modul_plant0/meshes/plant0_base.glb</uri>
              <scale>2 2 2</scale>
            </mesh>
          </geometry>
        </visual>
      </link>
      <link name="yapraklar">
        <pose>0 0 0.796845 0 0 0</pose>
        <visual name="yaprak_vis">
          <geometry>
            <mesh>
              <uri>model://Modul_plant0/meshes/plant0_leaves.glb</uri>
              <scale>2 2 2</scale>
            </mesh>
          </geometry>
        </visual>
      </link>
      <joint name="fide_to_yapraklar" type="fixed">
        <parent>fide_govdesi</parent>
        <child>yapraklar</child>
      </joint>
      <plugin filename="gz-sim-detachable-joint-system" name="gz::sim::systems::DetachableJoint">
        <parent_link>yapraklar</parent_link>
        <child_model>tomato_ripe_B_0_0</child_model>
        <child_link>link</child_link>
        <detach_topic>/detach/tomato_ripe_B_0_0</detach_topic>
        <attach_topic>/attach/tomato_ripe_B_0_0</attach_topic>
        <output_topic>/detach_state/tomato_ripe_B_0_0</output_topic>
