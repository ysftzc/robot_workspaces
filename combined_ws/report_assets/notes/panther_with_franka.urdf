    </joint>
    <actuator name="fr3_finger_joint2_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </actuator>
  </transmission>
  <gazebo reference="fr3_leftfinger">
    <collision>
      <max_contacts>10</max_contacts>
      <surface>
        <contact>
          <ode>
            <!-- These two parameter need application specific tuning. -->
            <!-- Usually you want no "snap out" velocity and a generous -->
            <!-- penetration depth to keep the grasping stable -->
            <max_vel>0</max_vel>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
        <friction>
          <ode>
            <mu>1.13</mu>
            <mu2>1.13</mu2>
          </ode>
        </friction>
        <bounce/>
      </surface>
    </collision>
  </gazebo>
  <gazebo reference="fr3_rightfinger">
    <collision>
      <max_contacts>10</max_contacts>
      <surface>
        <contact>
          <ode>
            <!-- These two parameter need application specific tuning. -->
            <!-- Usually you want no "snap out" velocity and a generous -->
            <!-- penetration depth to keep the grasping stable -->
            <max_vel>0</max_vel>
            <min_depth>0.001</min_depth>
          </ode>
        </contact>
        <friction>
          <ode>
            <mu>1.13</mu>
            <mu2>1.13</mu2>
          </ode>
        </friction>
        <bounce/>
      </surface>
    </collision>
  </gazebo>
  <!-- Local ros2_control block so Gazebo spawns the FR3 already looking at the
       right-side plant instead of starting folded downward and sweeping through
       front tomatoes. Keep this in this workspace instead of patching the
       upstream franka_description xacro. -->
  <ros2_control name="FrankaHardwareInterface" type="system">
    <hardware>
      <param name="version">1.0.0</param>
      <param name="robot_type">fr3</param>
      <param name="prefix"/>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="fr3_joint1">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">-1.71</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr3_joint2">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">-1.267</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr3_joint3">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr3_joint4">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">-2.792</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr3_joint5">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr3_joint6">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">2.8</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr3_joint7">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr3_finger_joint1">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.04</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="fr3_finger_joint2">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.04</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <gpio name="vx">
      <command_interface name="cartesian_velocity"/>
      <param name="index">0</param>
    </gpio>
    <gpio name="vy">
      <command_interface name="cartesian_velocity"/>
      <param name="index">1</param>
    </gpio>
    <gpio name="vz">
      <command_interface name="cartesian_velocity"/>
      <param name="index">2</param>
    </gpio>
    <gpio name="wx">
      <command_interface name="cartesian_velocity"/>
      <param name="index">3</param>
    </gpio>
    <gpio name="wy">
      <command_interface name="cartesian_velocity"/>
      <param name="index">4</param>
    </gpio>
    <gpio name="wz">
      <command_interface name="cartesian_velocity"/>
      <param name="index">5</param>
    </gpio>
    <gpio name="0">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">0</param>
    </gpio>
    <gpio name="1">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">1</param>
    </gpio>
    <gpio name="2">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">2</param>
    </gpio>
    <gpio name="3">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">3</param>
    </gpio>
    <gpio name="4">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">4</param>
    </gpio>
    <gpio name="5">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">5</param>
    </gpio>
    <gpio name="6">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">6</param>
    </gpio>
    <gpio name="7">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">7</param>
    </gpio>
    <gpio name="8">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">8</param>
    </gpio>
    <gpio name="9">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">9</param>
    </gpio>
    <gpio name="10">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">10</param>
    </gpio>
    <gpio name="11">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">11</param>
    </gpio>
    <gpio name="12">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">12</param>
    </gpio>
    <gpio name="13">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">13</param>
    </gpio>
    <gpio name="14">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">14</param>
    </gpio>
    <gpio name="15">
      <command_interface name="cartesian_pose_command"/>
      <param name="index">15</param>
    </gpio>
    <gpio name="joint_3_position">
      <command_interface name="elbow_command"/>
      <param name="index">0</param>
    </gpio>
    <gpio name="joint_4_sign">
      <command_interface name="elbow_command"/>
      <param name="index">1</param>
    </gpio>
  </ros2_control>
  <!-- Attach fr3_link0 to Panther mount_link -->
  <joint name="panther_to_franka_joint" type="fixed">
    <parent link="mount_link"/>
    <child link="fr3_link0"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
  </joint>
  <link name="fr3_camera_link">
    <visual>
      <origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://realsense2_description/meshes/d435.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.025 0.090 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.072"/>
      <inertia ixx="3.881e-3" ixy="0" ixz="0" iyy="4.989e-4" iyz="0" izz="3.879e-3"/>
    </inertial>
  </link>
  <joint name="fr3_camera_joint" type="fixed">
    <parent link="fr3_hand"/>
    <child link="fr3_camera_link"/>
    <!--
        xyz="0.10 0 0.08":
          +0.10m in TCP X = 10cm outward to the side (clears the ~8cm wrist body)
          +0.08m in TCP Z = 8cm toward wrist (TCP +Z points toward wrist, not fingertips)
        rpy="0 0 0": camera looks along TCP forward axis (link7 direction).
        If camera appears on the wrong side, flip X to -0.10 or swap to Y axis.
      -->
    <origin rpy="3.141592653589793 -1.5707963267948966 0" xyz="0.04 0 0.06"/>
  </joint>
  <!-- ROS optical frames (standard REP-103 convention) -->
  <link name="fr3_camera_color_optical_frame"/>
  <joint name="fr3_camera_color_optical_joint" type="fixed">
    <parent link="fr3_camera_link"/>
    <child link="fr3_camera_color_optical_frame"/>
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
  </joint>
  <link name="fr3_camera_depth_optical_frame"/>
  <joint name="fr3_camera_depth_optical_joint" type="fixed">
    <parent link="fr3_camera_link"/>
    <child link="fr3_camera_depth_optical_frame"/>
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
  </joint>
  <!-- Gazebo sensors: one color + one depth stream. -->
  <gazebo reference="fr3_camera_link">
    <sensor name="fr3_d435_color" type="camera">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>/camera/color/image_raw</topic>
      <camera name="fr3_d435_color_cam">
        <horizontal_fov>1.211</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>RGB_INT8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10</far>
        </clip>
      </camera>
    </sensor>
    <sensor name="fr3_d435_depth" type="depth_camera">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>/camera/depth/image</topic>
      <camera name="fr3_d435_depth_cam">
        <horizontal_fov>1.211</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>10</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <material name="soft_gripper_pad">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  <link name="fr3_leftfinger_tomato_pad">
    <visual name="fr3_leftfinger_tomato_pad_visual">
      <geometry>
        <box size="0.045 0.012 0.030"/>
      </geometry>
      <material name="soft_gripper_pad"/>
    </visual>
    <collision name="fr3_leftfinger_tomato_pad_collision">
      <geometry>
        <box size="0.045 0.012 0.030"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.015"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="1.305e-6" ixy="0" ixz="0" iyy="3.656e-6" iyz="0" izz="2.711e-6"/>
    </inertial>
  </link>
  <joint name="fr3_leftfinger_tomato_pad_joint" type="fixed">
    <parent link="fr3_leftfinger"/>
    <child link="fr3_leftfinger_tomato_pad"/>
    <origin rpy="0 0 0" xyz="0 0.00758 0.04525"/>
  </joint>
  <link name="fr3_rightfinger_tomato_pad">
    <visual name="fr3_rightfinger_tomato_pad_visual">
      <geometry>
        <box size="0.045 0.012 0.030"/>
      </geometry>
      <material name="soft_gripper_pad"/>
    </visual>
    <collision name="fr3_rightfinger_tomato_pad_collision">
      <geometry>
        <box size="0.045 0.012 0.030"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.015"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="1.305e-6" ixy="0" ixz="0" iyy="3.656e-6" iyz="0" izz="2.711e-6"/>
    </inertial>
  </link>
  <joint name="fr3_rightfinger_tomato_pad_joint" type="fixed">
    <parent link="fr3_rightfinger"/>
    <child link="fr3_rightfinger_tomato_pad"/>
    <origin rpy="0 0 0" xyz="0 0.00758 0.04525"/>
  </joint>
  <gazebo reference="fr3_leftfinger_tomato_pad">
    <mu1>1000</mu1>
    <mu2>1000</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0</maxVel>
  </gazebo>
  <gazebo reference="fr3_rightfinger_tomato_pad">
    <mu1>1000</mu1>
    <mu2>1000</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0</maxVel>
  </gazebo>
  <gazebo reference="fr3_leftfinger">
    <mu1>1000</mu1>
    <mu2>1000</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0</maxVel>
  </gazebo>
  <gazebo reference="fr3_rightfinger">
    <mu1>1000</mu1>
    <mu2>1000</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <minDepth>0.002</minDepth>
    <maxVel>0</maxVel>
  </gazebo>
  <!-- Lidar: uses Husarion's built-in LDR06 from components.yaml -->
</robot>
