    <joint name="fr3_joint3">
      <hardwareInterface>franka_hw/FrankaStateInterface</hardwareInterface>
    </joint>
    <joint name="fr3_joint4">
      <hardwareInterface>franka_hw/FrankaStateInterface</hardwareInterface>
    </joint>
    <joint name="fr3_joint5">
