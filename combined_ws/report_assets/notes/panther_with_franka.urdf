  <transmission name="fr3_franka_model">
    <type>franka_hw/FrankaModelInterface</type>
    <joint name="fr3_joint1">
      <role>root</role>
      <hardwareInterface>franka_hw/FrankaModelInterface</hardwareInterface>
    </joint>
    <joint name="fr3_joint8">
      <role>tip</role>
      <hardwareInterface>franka_hw/FrankaModelInterface</hardwareInterface>
    </joint>
    <actuator name="fr3_joint1_motor_root">
      <hardwareInterface>franka_hw/FrankaModelInterface</hardwareInterface>
    </actuator>
    <actuator name="fr3_joint8_motor_tip">
