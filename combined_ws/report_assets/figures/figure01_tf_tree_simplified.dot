digraph SimplifiedTFTree {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad="0.25",
    nodesep="0.30",
    ranksep="0.42",
    splines=ortho,
    fontname="DejaVu Sans"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="DejaVu Sans",
    fontsize=18,
    margin="0.12,0.08",
    color="#374151",
    fillcolor="#f8fafc"
  ];

  edge [
    fontname="DejaVu Sans",
    fontsize=13,
    color="#4b5563",
    arrowsize=0.75
  ];

  map [label="map\n(global map frame)", fillcolor="#e0f2fe"];
  odom [label="odom\n(local odometry frame)", fillcolor="#e0f2fe"];
  base_link [label="base_link\n(robot base frame)", fillcolor="#dcfce7"];
  body_link [label="body_link\n(Panther body)", fillcolor="#dcfce7"];
  cover_link [label="cover_link"];
  mount_link [label="mount_link\n(FR3 mount)"];

  wheels [label="wheel frames\nfl/fr/rl/rr wheels", fillcolor="#fef9c3"];
  lidar [label="rplidar_link -> laser\n2D LiDAR", fillcolor="#fef9c3"];
  imu [label="imu_link\nIMU", fillcolor="#fef9c3"];
  baskets [label="good_basket_link\nbad_basket_link", fillcolor="#fde68a"];

  fr3_base [label="fr3_link0\n(FR3 base)", fillcolor="#ede9fe"];
  fr3_chain [label="fr3_link1 ... fr3_link8\n7-DOF arm chain", fillcolor="#ede9fe"];
  hand [label="fr3_hand\nfr3_hand_tcp", fillcolor="#ede9fe"];
  fingers [label="fr3_leftfinger / rightfinger\ntomato gripper pads", fillcolor="#ede9fe"];

  camera_link [label="fr3_camera_link\nRGB-D camera body", fillcolor="#fee2e2"];
  camera_optical [label="fr3_camera_color_optical_frame\nfr3_camera_depth_optical_frame", fillcolor="#fee2e2"];

  map -> odom;
  odom -> base_link;
  base_link -> body_link;
  base_link -> baskets;
  body_link -> wheels;
  body_link -> imu;
  body_link -> cover_link;
  cover_link -> mount_link;
  mount_link -> lidar;
  mount_link -> fr3_base;
  fr3_base -> fr3_chain;
  fr3_chain -> hand;
  hand -> fingers;
  hand -> camera_link;
  camera_link -> camera_optical;

  note [
    shape=note,
    label="Simplified for report readability.\nAccelerometer frames and repeated wheel/base helper frames are omitted.\nFull TF export is kept separately.",
    fillcolor="#f3f4f6",
    color="#9ca3af",
    fontsize=14
  ];
  camera_optical -> note [style=dashed, arrowhead=none, color="#9ca3af"];
}
