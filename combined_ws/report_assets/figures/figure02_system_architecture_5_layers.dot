digraph SystemArchitectureCompact {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad="0.25",
    nodesep="0.28",
    ranksep="0.32",
    splines=line,
    dpi=220,
    fontname="DejaVu Sans",
    labelloc=t,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD><FONT POINT-SIZE="28"><B>Overall System Architecture</B></FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="15" COLOR="#64748B">Five-layer greenhouse harvesting pipeline</FONT></TD></TR>
      </TABLE>
    >
  ];

  node [
    shape=plain,
    fontname="DejaVu Sans",
    fontsize=16
  ];

  edge [
    fontname="DejaVu Sans",
    fontsize=12,
    color="#64748B",
    penwidth=2.0,
    arrowsize=0.72
  ];

  layer1 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="10" COLOR="#7DD3FC">
      <TR><TD BGCOLOR="#0284C7"><FONT COLOR="white" POINT-SIZE="18"><B>Layer 1 - Simulation and Robot Platform</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#EFF8FF">
        <B>Role:</B> Gazebo greenhouse world, robot body,<BR ALIGN="LEFT"/>
        crops, baskets, and sensor models<BR ALIGN="LEFT"/>
        <B>Main elements:</B> Panther base, Franka FR3 arm,<BR ALIGN="LEFT"/>
        RGB-D camera, LiDAR, IMU, B/C tomato rows
      </TD></TR>
    </TABLE>
  >];

  layer2 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="10" COLOR="#86EFAC">
      <TR><TD BGCOLOR="#16A34A"><FONT COLOR="white" POINT-SIZE="18"><B>Layer 2 - ROS2 Interface and Robot State</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#F0FDF4">
        <B>Role:</B> Bridge simulation data into ROS2<BR ALIGN="LEFT"/>
        and expose robot commands/state<BR ALIGN="LEFT"/>
        <B>Main modules:</B> ros_gz_bridge, ros2_control,<BR ALIGN="LEFT"/>
        robot_state_publisher, TF2 tree
      </TD></TR>
    </TABLE>
  >];

  layer3 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="10" COLOR="#FDBA74">
      <TR><TD BGCOLOR="#EA580C"><FONT COLOR="white" POINT-SIZE="18"><B>Layer 3 - Navigation and Localization</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#FFF7ED">
        <B>Role:</B> Localize the base on the map<BR ALIGN="LEFT"/>
        and follow plant-row goals<BR ALIGN="LEFT"/>
        <B>Main modules:</B> SLAM Toolbox, AMCL,<BR ALIGN="LEFT"/>
        robot_localization EKF, Nav2
      </TD></TR>
    </TABLE>
  >];

  layer4 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="10" COLOR="#F9A8D4">
      <TR><TD BGCOLOR="#DB2777"><FONT COLOR="white" POINT-SIZE="18"><B>Layer 4 - Perception and Tomato Mapping</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#FDF2F8">
        <B>Role:</B> Detect tomatoes, estimate 3D positions,<BR ALIGN="LEFT"/>
        and publish a live tomato map<BR ALIGN="LEFT"/>
        <B>Main modules:</B> YOLO detector, TomatoDepthMapper,<BR ALIGN="LEFT"/>
        /tomato_map/list, bbox viewer, map panel
      </TD></TR>
    </TABLE>
  >];

  layer5 [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="10" COLOR="#C4B5FD">
      <TR><TD BGCOLOR="#7C3AED"><FONT COLOR="white" POINT-SIZE="18"><B>Layer 5 - Mission, Planning, and Harvesting</B></FONT></TD></TR>
      <TR><TD BGCOLOR="#F5F3FF">
        <B>Role:</B> Select targets, avoid obstacles,<BR ALIGN="LEFT"/>
        and execute pick-place motions<BR ALIGN="LEFT"/>
        <B>Main modules:</B> MissionManager, collision scene,<BR ALIGN="LEFT"/>
        target selector, MoveIt/OMPL, Pilz LIN
      </TD></TR>
    </TABLE>
  >];

  feedback [label=<
    <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7">
      <TR><TD BGCOLOR="#F8FAFC"><FONT COLOR="#475569" POINT-SIZE="13">
        Closed-loop execution: commands return to controllers; Gazebo attach/detach updates tomato state.
      </FONT></TD></TR>
    </TABLE>
  >];

  layer1 -> layer2 [label="simulation data", color="#0284C7"];
  layer2 -> layer3 [label="scan, odom, TF", color="#16A34A"];
  layer2 -> layer4 [label="RGB-D + TF", color="#DB2777"];
  layer3 -> layer5 [label="pose + waypoints", color="#EA580C"];
  layer4 -> layer5 [label="tomato map", color="#7C3AED"];
  layer5 -> feedback [style=dashed, color="#64748B", arrowhead=none];
  feedback -> layer2 [label="motion commands", color="#334155", constraint=false];
}
