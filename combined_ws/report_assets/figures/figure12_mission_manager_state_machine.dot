digraph MissionManagerStateMachine {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad="0.25",
    nodesep="0.45",
    ranksep="0.65",
    splines=polyline,
    outputorder=edgesfirst
  ];

  node [
    fontname="DejaVu Sans",
    fontsize=20,
    margin="0.18,0.12",
    penwidth=2.0,
    color="#25323f",
    fontcolor="#17212b",
    style="rounded,filled",
    fillcolor="#f7fafc",
    shape=box
  ];

  edge [
    fontname="DejaVu Sans",
    fontsize=17,
    color="#52616f",
    fontcolor="#334155",
    arrowsize=0.85,
    penwidth=1.8
  ];

  start [
    label="Start",
    shape=circle,
    width=0.95,
    fixedsize=true,
    fillcolor="#17212b",
    fontcolor="white",
    color="#17212b"
  ];

  localize [
    label=<<B>LOCALIZE</B><BR/><FONT POINT-SIZE="15">wait for /amcl_pose</FONT>>,
    fillcolor="#e7f5ff",
    color="#1871b8"
  ];

  boot [
    label=<<B>BOOT</B><BR/><FONT POINT-SIZE="15">ready / idle</FONT>>,
    fillcolor="#eef2ff",
    color="#4f46e5"
  ];

  start_gate [
    label="start service or autostart?",
    shape=diamond,
    width=2.45,
    height=1.1,
    margin="0.12,0.08",
    fillcolor="#fff7ed",
    color="#ea580c"
  ];

  route [
    label=<<B>Load route waypoint</B><BR/><FONT POINT-SIZE="15">state, Nav2 pose, arm pose</FONT>>,
    fillcolor="#f8fafc",
    color="#475569"
  ];

  mission_phase [
    label=<<B>SURVEY_UPPER / CENTER / LOWER</B><BR/><B>or HARVESTING</B><BR/><FONT POINT-SIZE="15">sync state from waypoint</FONT>>,
    fillcolor="#ecfeff",
    color="#0891b2"
  ];

  arm_pose [
    label=<<B>FR3 observation pose</B><BR/><FONT POINT-SIZE="15">scan / pick-front joint pose</FONT>>,
    fillcolor="#f0fdf4",
    color="#16a34a"
  ];

  nav [
    label=<<B>Navigate to waypoint</B><BR/><FONT POINT-SIZE="15">Nav2 goal or direct yaw turn</FONT>>,
    fillcolor="#f8fafc",
    color="#475569"
  ];

  reached [
    label="waypoint reached?",
    shape=diamond,
    width=2.35,
    height=1.1,
    margin="0.12,0.08",
    fillcolor="#fff7ed",
    color="#ea580c"
  ];

  pick_trigger [
    label="pick trigger waypoint?",
    shape=diamond,
    width=2.55,
    height=1.1,
    margin="0.12,0.08",
    fillcolor="#fff7ed",
    color="#ea580c"
  ];

  target_select [
    label=<<B>Select harvest target</B><BR/><FONT POINT-SIZE="15">tomato map + class filters</FONT><BR/><FONT POINT-SIZE="14">green rejected, ripe/rotten routed</FONT>>,
    fillcolor="#fff1f2",
    color="#e11d48"
  ];

  publish_target [
    label=<<B>Publish pick target</B><BR/><FONT POINT-SIZE="15">/tomato_harvest/target_selection</FONT><BR/><FONT POINT-SIZE="15">/mission_pick/tomato_center</FONT>>,
    fillcolor="#fff1f2",
    color="#e11d48"
  ];

  pick_place [
    label=<<B>Pick-place subprocess</B><BR/><FONT POINT-SIZE="15">MoveIt OMPL approach</FONT><BR/><FONT POINT-SIZE="15">Pilz LIN grasp, basket drop</FONT>>,
    fillcolor="#fff1f2",
    color="#e11d48"
  ];

  pick_result [
    label="pick success?",
    shape=diamond,
    width=2.15,
    height=1.1,
    margin="0.12,0.08",
    fillcolor="#fff7ed",
    color="#ea580c"
  ];

  done [
    label=<<B>DONE</B><BR/><FONT POINT-SIZE="15">route complete</FONT>>,
    fillcolor="#dcfce7",
    color="#15803d"
  ];

  stopped [
    label=<<B>STOPPED</B><BR/><FONT POINT-SIZE="15">manual stop</FONT>>,
    fillcolor="#f1f5f9",
    color="#64748b"
  ];

  failed [
    label=<<B>FAILED</B><BR/><FONT POINT-SIZE="15">timeout / action failure</FONT>>,
    fillcolor="#fee2e2",
    color="#dc2626"
  ];

  start -> localize [label="localization gate"];
  start -> boot [label="stationary mode"];
  localize -> boot [label="/amcl_pose ready"];
  boot -> start_gate;
  start_gate -> route [label="yes"];
  start_gate -> boot [label="wait", color="#94a3b8"];

  route -> mission_phase;
  mission_phase -> arm_pose [label="if arm pose configured"];
  mission_phase -> nav [label="otherwise"];
  arm_pose -> nav [label="pose reached / skipped"];
  nav -> reached;

  reached -> nav [label="retry", color="#ca8a04"];
  reached -> failed [label="timeout and stop_on_failure"];
  reached -> pick_trigger [label="yes"];
  pick_trigger -> route [label="no: next waypoint"];
  pick_trigger -> target_select [label="yes"];
  target_select -> route [label="no valid target / max attempts", color="#94a3b8"];
  target_select -> publish_target [label="selected"];
  publish_target -> pick_place;
  pick_place -> pick_result;
  pick_result -> route [label="success: mark picked, next target/waypoint"];
  pick_result -> route [label="failure: skip target if allowed", color="#ca8a04"];
  pick_result -> failed [label="failure and stop_on_failure"];

  route -> done [label="end of route"];
  boot -> stopped [label="stop service", color="#64748b"];
  route -> stopped [label="stop service", color="#64748b"];
  mission_phase -> stopped [label="stop service", color="#64748b"];
  nav -> stopped [label="stop service", color="#64748b"];
  pick_place -> stopped [label="stop service", color="#64748b"];
  stopped -> boot [label="reset"];
  failed -> boot [label="reset"];
}
